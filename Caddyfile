{
    admin off
}

{$DOMAIN_CLOUD} {
    # Redirection des chemins WebDAV
    redir /.well-known/carddav /remote.php/dav permanent
    redir /.well-known/caldav /remote.php/dav permanent
    redir /.well-known /index.php{uri} permanent

    # Protection des fichiers sensibles
    @sensitive {
        path /.htaccess /data/* /config/* /db_structure.xml /README
    }
    respond @sensitive 403

    # Configuration du proxy
    reverse_proxy app:80 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-Port {server_port}
    }

    # En-têtes de sécurité
    header {
        Strict-Transport-Security "max-age=15768000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
    }

    # Cache pour les fichiers statiques
    @static {
        file
        path *.ico *.css *.js *.gif *.jpg *.jpeg *.png *.svg *.woff *.woff2
    }
    header @static Cache-Control "public, max-age=31536000"

    # Configuration des timeouts
    timeouts {
        read_body 3600s
        read_header 3600s
        write 3600s
        idle 3600s
    }

    # Taille maximale des uploads
    request_body {
        max_size 32GB
    }
} 